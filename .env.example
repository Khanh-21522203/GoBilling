# Environment
GOBILLING_ENV=development

# Server
PORT=8080

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=gobilling
DB_USER=gobilling_app
DB_PASSWORD=changeme
DB_SSL_MODE=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# Secrets Management
SECRETS_BACKEND=env

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Observability
OTEL_ENABLED=false
OTEL_EXPORTER_JAEGER_ENDPOINT=http://localhost:14268/api/traces
METRICS_ENABLED=true

# Rate Limiting
RATE_LIMIT_READ_PER_MINUTE=1000
RATE_LIMIT_WRITE_PER_MINUTE=200

# Payment Provider (Stub for MVP)
PAYMENT_PROVIDER=stub
PAYMENT_PROVIDER_SUCCESS_RATE=0.9
